# Copy this file to .env and adjust values for your environment.
# .env is gitignored and should never be committed.

# Path to the data directory (DuckDB database and CSV imports)
DATA_DIR=./data

# JWT signing secret — required for authentication (Phase 11 Block 3).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Override the DuckDB database file (e.g. to run the app against the demo dataset)
# HL_DB_PATH=./data/hl_demo.duckdb

# Morningstar unofficial API token — embedded in Morningstar's own web pages.
# The default value works as of 2025; if fetches start returning 401/403,
# inspect the Network tab on morningstar.co.uk to find the current token.
# MORNINGSTAR_API_TOKEN=9vehuxllxs

# Telegram notifications and query bot (Phases 7a/7b)
# Create a bot via @BotFather to get the token; get your chat ID from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Anthropic API key — used by the Telegram query bot (Phase 7b)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the Claude model used by the bot (default: claude-haiku-4-5-20251001)
# CLAUDE_MODEL=claude-haiku-4-5-20251001
