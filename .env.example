# Copy this file to .env and adjust values for your environment.
# .env is gitignored and should never be committed.

# Path to the data directory (DuckDB database and CSV imports)
DATA_DIR=./data

# Morningstar unofficial API token — embedded in Morningstar's own web pages.
# The default value works as of 2025; if fetches start returning 401/403,
# inspect the Network tab on morningstar.co.uk to find the current token.
# MORNINGSTAR_API_TOKEN=9vehuxllxs
